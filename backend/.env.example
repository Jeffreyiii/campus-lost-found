# Flask 后端环境变量（复制为 .env 后填写）
# copy .env.example .env

# Flask 配置
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# Supabase 云数据库配置
# 在 https://supabase.com 创建项目后，从 Settings → API 获取
# 注意：supabase-py 稳定版不兼容新版短格式 secret key (sb_secret_)，请使用 publishable anon key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-publishable-anon-key

# 说明：
# - 使用 anon key（sb_publishable_ 开头），需先在 Supabase SQL Editor 执行 db/schema.sql 中的 RLS 策略
# - service_role key（sb_secret_ 开头）因 supabase-py 本地 JWT 格式校验不兼容，暂时无法使用
# - 未填写以上两项时，系统自动回退到内存存储模式
